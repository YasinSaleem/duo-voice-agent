{
  "name": "api",
  "version": "1.0.0",
  "description": "Voice AI Spanish Language Tutor API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "doctor": "ts-node src/doctor.ts",
    "dev:all": "concurrently --names \"api,grammar,memory\" --prefix-colors \"blue,green,magenta\" \"npm run dev\" \"cd .. && python3 -m agent.workers.grammar_worker\" \"cd .. && python3 -m agent.workers.memory_worker\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@upstash/redis": "^1.38.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "livekit-server-sdk": "^2.15.3",
    "mongodb": "^7.2.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
